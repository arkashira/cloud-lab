{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Simulated CloudFront Distribution",
  "type": "object",
  "required": ["id", "custom_domain"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the simulated distribution."
    },
    "custom_domain": {
      "type": "string",
      "pattern": "^(?!-)[A-Za-z0-9-]{1,63}(?<!-)(\\.(?!-)[A-Za-z0-9-]{1,63}(?<!-))*$",
      "description": "Custom domain attached to the distribution. Must be a valid DNS name."
    }
  },
  "additionalProperties": false
}